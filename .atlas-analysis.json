  "publicApiSurface": [
    "cli.py run - Execute full analytics pipeline",
    "cli.py manifest - Generate dataset manifest",
    "cli.py early-warning-experiment - Run hardware-constrained experiments",
    "SimpleLogisticModel - Custom logistic regression implementation",
    "OutlierDetector - Anomaly detection system",
    "train_predictive_models() - Train risk and outcome models",
    "stratify_risk() - Risk band classification",
    "simulate_early_warning() - Early warning alert generation",
    "run_streaming_inference() - Real-time model scoring",
    "export_pipeline_to_onnx() - Model serialization",
    "build_monitoring_summary() - Deployment metrics",
    "run_hardware_constrained_early_warning_experiment() - Constraint scenario evaluation",
